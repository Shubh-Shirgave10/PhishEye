{
    "manifest_version": 3,
    "name": "PhishEye",
    "version": "1.0",
    "description": "Phishing Detection System Extension",
    "permissions": [
        "activeTab",
        "storage",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:5000/*",
        "https://phisheye-2-dbpr.onrender.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}